# PostgreSQL connection (SQLAlchemy URL)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/hiresense

# Optional: development secret (not for production auth)
SECRET_KEY=replace-with-long-random-string

# Upload storage directory relative to project root
UPLOAD_DIR=uploads

# Max upload size hint (MB) — also configure Streamlit server maxMessageSize
MAX_UPLOAD_MB=25

APP_ENV=development
